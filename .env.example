APP_NAME=JobVisa.lk
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/jobvisa
APP_TIMEZONE=Asia/Colombo

# Production readiness (Sprint 4.1)
APP_MAINTENANCE=false
MAINTENANCE_SECRET=
MAINTENANCE_ALLOW_IP=
FORCE_HTTPS=false
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=false
HSTS_MAX_AGE=31536000
SECURITY_FRAME_OPTIONS=SAMEORIGIN
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
FAIL_ON_INSECURE_PRODUCTION=true
TRUSTED_PROXIES=
# Production: set comma-separated proxy IPs. Empty list only trusts XFF in local/testing/development.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=jobvisa_db
DB_USER=root
DB_PASSWORD=

SESSION_NAME=jobvisa_session
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax

RATE_LIMIT_ENABLED=true

# Security hardening (Sprint 4.7)
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_MIXED=false
PASSWORD_REQUIRE_NUMBER=false
PASSWORD_REQUIRE_SYMBOL=false
PASSWORD_ALGO=argon2id
CSP_ENABLED=true
SECURITY_AUDIT_ENABLED=true
REMEMBER_PEPPER_ENABLED=false
CSRF_TOKEN_KEY=_csrf_token

# Performance & optimization (Sprint 4.2)
PERF_ENABLED=true
CACHE_ENABLED=true
CACHE_DRIVER=file
CACHE_PREFIX=jobvisa
CACHE_TTL=3600
CATALOG_CACHE_TTL=3600
QUERY_PROFILE=false
SLOW_QUERY_MS=100
QUERY_BUDGET=40
RESPONSE_TIMING=true
SLOW_REQUEST_MS=800
DEFAULT_PER_PAGE=15
MAX_PER_PAGE=50

# Monitoring & observability (Sprint 4.3)
OBS_ENABLED=true
OBS_REQUEST_ID_HEADER=X-Request-Id
OBS_ACCESS_LOG=true
OBS_ACCESS_LOG_SAMPLE=100
OBS_METRICS_ENABLED=true
OBS_METRICS_SECRET=
OBS_ERROR_TRACKING=true
OBS_ERROR_RING_SIZE=50
OBS_ALERT_WEBHOOK_URL=
OBS_ALERT_ON_5XX=false

# Enterprise API platform (Sprint 4.5)
API_ENABLED=true
API_DEFAULT_VERSION=v1
API_TOKEN_PREFIX=jv1_
API_TOKEN_BYTES=32
API_TOKEN_TTL_DAYS=365
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_DRIVER=file
API_RATE_LIMIT_PER_MINUTE=120
API_RATE_LIMIT_AUTH_PER_MINUTE=240
API_CORS_ENABLED=true
API_CORS_ORIGINS=
# Production: comma-separated browser origins. Empty allow-list only reflects Origin in local-like envs.
API_CORS_MAX_AGE=86400
API_AUDIT_ENABLED=true
API_WEBHOOKS_ENABLED=false
# Keep webhooks off until SSRF hardening is complete.
API_DOCS_ENABLED=true

# Developer portal & SDK (Sprint 4.6)
DEV_PORTAL_ENABLED=true
DEV_SDK_ENABLED=true
DEV_PORTAL_TRY_IT=true
DEV_PORTAL_API_BASE=

# Required for PAT HMAC in staging/production. Changing APP_KEY invalidates existing API tokens.
APP_KEY=

# Deployment automation (Sprint 4.4)
DEPLOY_ENABLED=true
DEPLOY_CONFIRM_TOKEN=DEPLOY
DEPLOY_REQUIRE_CONFIRM=true
DEPLOY_BACKUP_ENABLED=true
DEPLOY_BACKUP_RETENTION=14
MYSQLDUMP_PATH=
MYSQL_CLI_PATH=
DEPLOY_RUN_CHECKS=true
DEPLOY_OPTIMIZE_AUTOLOAD=true
DEPLOY_WARM_CACHE=true

# Database seeders (local/demo only — change before shared environments)
SEED_ADMIN_EMAIL=admin@jobvisa.lk
SEED_ADMIN_PASSWORD=ChangeMeAdmin!123
SEED_ADMIN_NAME="System Administrator"
SEED_EMPLOYER_EMAIL=employer@demo.jobvisa.lk
SEED_EMPLOYER_PASSWORD=ChangeMeEmployer!123
SEED_EMPLOYER_NAME="Demo Employer"
SEED_SEEKER_EMAIL=seeker@demo.jobvisa.lk
SEED_SEEKER_PASSWORD=ChangeMeSeeker!123
SEED_SEEKER_NAME="Demo Job Seeker"
