{
  "openapi": "3.0.3",
  "info": {
    "title": "JobVisa.lk Enterprise API",
    "description": "Versioned JSON API platform (Sprint 4.5 + hardening). Authenticate with personal access tokens via Authorization: Bearer <token>. Rate-limit headers: X-RateLimit-Limit, X-RateLimit-Remaining, X-RateLimit-Reset; Retry-After on 429. Token expires_at is UTC. Set APP_KEY for PAT hashing. Webhooks remain disabled by default (SSRF hardening pending).",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "/api/v1", "description": "API v1" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "PAT",
        "description": "Bearer credential: short-lived session access token (jva1_…) or long-lived personal access token (jv1_…). Refresh tokens (jvr1_…) are not accepted here."
      }
    },
    "schemas": {
      "SuccessEnvelope": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "type": "object" },
          "meta": { "type": "object" },
          "request_id": { "type": "string" }
        }
      },
      "ErrorEnvelope": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "details": { "type": "object" }
            }
          },
          "request_id": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/portal": {
      "get": {
        "summary": "Developer portal readiness",
        "responses": {
          "200": { "description": "OK" },
          "503": { "description": "Degraded" }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "API health",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" },
                "example": {
                  "success": true,
                  "data": { "status": "ok", "api_version": "v1" },
                  "meta": {},
                  "request_id": "abc123"
                }
              }
            }
          }
        }
      }
    },
    "/jobs": {
      "get": {
        "summary": "List published jobs (search, filters, pagination)",
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string", "maxLength": 120 } },
          { "name": "country_id", "in": "query", "schema": { "type": "integer", "minimum": 1 } },
          { "name": "job_type_id", "in": "query", "schema": { "type": "integer", "minimum": 1 } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1 } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 100 } },
          { "name": "limit", "in": "query", "description": "Legacy alias for per_page", "schema": { "type": "integer", "minimum": 1, "maximum": 100 } },
          { "name": "include_filters", "in": "query", "schema": { "type": "string", "enum": ["1", "true"] } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/jobs/{job}": {
      "get": {
        "summary": "Get published job (detailed public payload)",
        "parameters": [
          { "name": "job", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" } }
      }
    },
    "/me": {
      "get": {
        "summary": "Current authenticated user",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/resumes": {
      "get": {
        "summary": "List own resumes",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/resumes/{resume}": {
      "get": {
        "summary": "Get own resume",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "resume", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" } }
      }
    },
    "/resumes/{resume}/intelligence": {
      "get": {
        "summary": "Resume intelligence snapshot",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/jobs/{job}/match": {
      "get": {
        "summary": "Match resume to job",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "job", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "resume_id", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/jobs/{job}/applications": {
      "post": {
        "summary": "Apply to a published job",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "job", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "201": { "description": "Created" },
          "409": { "description": "Already applied" },
          "422": { "description": "Validation / job not open" }
        }
      }
    },
    "/applications": {
      "get": {
        "summary": "List own applications",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" }, "403": { "description": "Forbidden" } }
      }
    },
    "/applications/{application}": {
      "get": {
        "summary": "Get own application",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "application", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" } }
      }
    },
    "/applications/{application}/withdraw": {
      "post": {
        "summary": "Withdraw own application (submitted|reviewing only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "application", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" }, "422": { "description": "Invalid transition" } }
      }
    },
    "/employer/jobs": {
      "get": {
        "summary": "Employer-owned jobs",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" }, "403": { "description": "Forbidden" } }
      },
      "post": {
        "summary": "Create employer job (draft or published)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Created" },
          "403": { "description": "Forbidden" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/employer/jobs/{job}": {
      "get": {
        "summary": "Get owned job (detailed)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "job", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" } }
      },
      "post": {
        "summary": "Update owned job",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "job", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "OK" },
          "404": { "description": "Not found" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/employer/jobs/{job}/publish": {
      "post": {
        "summary": "Publish owned job (self-publish)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "job", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" } }
      }
    },
    "/employer/jobs/{job}/unpublish": {
      "post": {
        "summary": "Unpublish owned job (status → draft)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "job", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" } }
      }
    },
    "/employer/jobs/{job}/archive": {
      "post": {
        "summary": "Archive owned job (status → closed, soft archive)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "job", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" } }
      }
    },
    "/employer/jobs/{job}/applicants": {
      "get": {
        "summary": "Applicants for owned job",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/employer/applications/{application}": {
      "get": {
        "summary": "Applicant detail for owned job application",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "application", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" } }
      }
    },
    "/employer/applications/{application}/status": {
      "post": {
        "summary": "Update application status (employer)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "application", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "OK" },
          "404": { "description": "Not found" },
          "422": { "description": "Invalid transition" }
        }
      }
    },
    "/employer/jobs/{job}/ranking": {
      "get": {
        "summary": "Applicant ranking for owned job",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/tokens": {
      "get": {
        "summary": "List personal access tokens (metadata only)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "summary": "Create personal access token",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "example": "CI bot" },
                  "ttl_days": { "type": "integer", "example": 90 }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Created — plaintext token returned once" } }
      }
    },
    "/tokens/revoke-all": {
      "post": {
        "summary": "Revoke all personal access tokens for the current user",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/tokens/{token}/revoke": {
      "post": {
        "summary": "Revoke a personal access token",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Token id (not the plaintext secret)"
          }
        ],
        "responses": {
          "200": { "description": "Revoked" },
          "404": { "description": "Not found / not owned" }
        }
      }
    },
    "/auth/status": {
      "get": {
        "summary": "Auth Token Lifecycle v2 readiness",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Password login → short-lived access token + refresh (device bound; access not a PAT)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "device_name": { "type": "string" },
                  "device_fingerprint": { "type": "string" },
                  "platform": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Issued access + refresh" },
          "401": { "description": "Invalid credentials / MFA required" },
          "429": { "description": "Account lockout" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "summary": "Rotate refresh → new access + refresh (old refresh unusable; access never renewed directly)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refresh_token"],
                "properties": { "refresh_token": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "New access + refresh" },
          "401": { "description": "Invalid / reused / expired" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Logout current API session",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/logout-everywhere": {
      "post": {
        "summary": "Revoke all devices, refresh families, and PATs",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/devices": {
      "get": {
        "summary": "List device sessions",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/devices/{device}/revoke": {
      "post": {
        "summary": "Revoke a device and its refresh tokens",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "device", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" } }
      }
    },
    "/auth/password/forgot": {
      "post": {
        "summary": "Request password reset email",
        "responses": { "200": { "description": "Always generic success (anti-enumeration)" } }
      }
    },
    "/auth/password/reset": {
      "post": {
        "summary": "Reset password with emailed token",
        "responses": { "200": { "description": "OK" }, "422": { "description": "Validation" } }
      }
    },
    "/auth/email/verify": {
      "post": {
        "summary": "Verify email with token",
        "responses": { "200": { "description": "OK" }, "422": { "description": "Invalid token" } }
      }
    },
    "/auth/email/resend": {
      "post": {
        "summary": "Resend email verification",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/mfa": {
      "get": {
        "summary": "MFA-ready factor status",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/auth/mfa/register": {
      "post": {
        "summary": "Register MFA factor placeholder (challenge deferred)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/docs/openapi": {
      "get": {
        "summary": "OpenAPI 3 document",
        "description": "Returns raw OpenAPI JSON by default. Pass ?envelope=1 to wrap in the SuccessEnvelope.",
        "parameters": [
          {
            "name": "envelope",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OpenAPI document",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    }
  }
}
